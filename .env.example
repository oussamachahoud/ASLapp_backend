# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=your-BD-name
DB_USERNAME=postgres
DB_PASSWORD=changeme
# DB_URL is auto-set by docker-compose; override here only for local (non-Docker) runs:
# DB_URL=jdbc:postgresql://localhost:5432/aslapp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-base64-secret
JWT_EXPIRATION_TIME=86400000

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
